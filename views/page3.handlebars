<html lang="en">

<head>
  <meta charset="utf-8" />
  <!-- passed in variables in handlebars are surrounded by two curly braces like the following
       Any variable you pass into res.render will be available by name in the template through
       the curly braces
  -->
  <title>{{title}}</title>
</head>

<body>
  <h1>Welcome to page 3</h1>

  <!-- links or URLs are always GET resources as they are getting (retrieving) a resource -->
  <a href="/">Home</a>
  <a href="/page1">Page 1</a>
  <a href="/page2">Page 2</a>
  <a href="/page4">Page 4</a>

  <form action="/setDogName" method="POST">
    <label for="firstname">First name:</label>
    <input type="text" name="firstname" value="">
    <label for="lastname">Last Name: </label>
    <input type="text" name="lastname" value="">
    <label for="breed">Breed:</label>
    <input type="string" name="breed" value="">
    <label for="age">Dog age </label>
    <input type="number" id="age" name="age" min="1" value="">
    <input type="submit" value="submit">
  </form>

  <br />
  <br />


  <form action="/updateLastDog" method="POST">
    <input type="submit" value="Update Last">
  </form>

  <br />
  <br />


  <form action="findDogByName" method="GET">
    <label for="name">Search by dog name:</label>
    <input type="text" name="name" value="">
    <label for="age">Increase dog age by (if empty, auto increament by 1): </label>
    <input type="number" id="age" name="age" min="1" value="">
    <input type="submit" value="Submit">
  </form>

</body>

</html>